# ============================================================================
# Environment variables for the event registration app.
# Copy to .env.local for local dev, and set the same keys in Vercel.
# NEXT_PUBLIC_* values are exposed to the browser. Everything else is
# server-only and must NEVER be prefixed with NEXT_PUBLIC_.
# ============================================================================

# --- Site ---
# Public base URL of the deployed site, e.g. https://yourdomain.com
# Used to build QR /entry links and the Razorpay balance-payment callback URL.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key: Supabase Dashboard > Settings > API > service_role.
# SERVER-ONLY. Grants full DB access (bypasses RLS). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Razorpay ---
# Requires EMI + Payment Links enabled on the account, and the webhook
# subscribed to BOTH `payment.captured` and `payment_link.paid`.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# --- Email (ZeptoMail HTTP API) ---
# Provider-neutral names. The provider itself is isolated in lib/email.js — to
# switch, change deliver() there. No call site needs to change.
# ZeptoMail: Mail Agent → Setup → API → copy the "Send Mail Token". The
# 'Zoho-enczapikey ' prefix is optional (added automatically if you omit it).
EMAIL_API_KEY=Zoho-enczapikey_xxx
# Verified sending-domain address, e.g. "BaglaBhairav <tickets@yourdomain.com>".
# MUST be an address on the domain you verified (SPF+DKIM) inside ZeptoMail.
EMAIL_FROM="BaglaBhairav <tickets@yourdomain.com>"
# Data-centre endpoint. Default = INDIA (api.zeptomail.in). If your ZeptoMail
# account is on the global/US DC, set this to the .com host instead. The host
# MUST match the DC your token belongs to, or every send returns 401.
# EMAIL_API_URL=https://api.zeptomail.com/v1.1/email
# Legacy names, still read as a fallback (set EMAIL_API_KEY to the ZeptoMail token
# to actually send — the token format differs from Resend): RESEND_API_KEY / RESEND_FROM

# --- WhatsApp Cloud API (optional; confirmation, payment/balance link, QR, waitlist, broadcast) ---
# WHATSAPP_API_URL = https://graph.facebook.com/v21.0/<PHONE_NUMBER_ID>/messages
# Business-initiated messages require APPROVED message templates in Meta —
# free-form text only delivers inside a 24-hour customer-service window.
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=

# WhatsApp TEMPLATE NAMES — all configured centrally in lib/whatsapp.js.
# Only set these if your Meta-approved template names DIFFER from the defaults
# shown below; otherwise leave them blank and name your templates to match.
# The required body-parameter order for each is documented in lib/whatsapp.js.
#   ticketConfirmation  params: [name, tier, paymentRef]
#   announcement        params: [message]
#   paymentLink         params: [name, tier, amount, payLink]
#   waitlistOpen        params: [name, tier, registerLink]
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_TEMPLATE_TICKET=ticket_confirmation
WHATSAPP_TEMPLATE_ANNOUNCE=announcement
WHATSAPP_TEMPLATE_PAYMENT=payment_link
WHATSAPP_TEMPLATE_WAITLIST=waitlist_open
# MEDIA-HEADER templates — approve these with a header FORMAT of IMAGE / DOCUMENT.
# They are what lets a file reach someone OUTSIDE the 24h window; a plain image or
# document message is free-form and will be rejected for a website registrant.
#   entry_pass            header: IMAGE     params: [name, tier, attendees, passLink]
#   document_announcement header: DOCUMENT  params: [message]
WHATSAPP_TEMPLATE_ENTRY_PASS=entry_pass
WHATSAPP_TEMPLATE_DOC_ANNOUNCE=document_announcement

# --- Entry scanner ---
# No env var. /scan uses the SAME named accounts as the admin panel: give a
# volunteer the "Scan entry passes at the gate" (checkin:scan) permission in
# Settings → Admin Users. The old shared SCANNER_PIN was removed — it couldn't be
# attributed to a person or revoked for one volunteer without a redeploy.

# --- Admin auth ---
# Used to sign the admin session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET=du4in6ncuniudn2n98ncuskubx423asb
# There is NO admin password in env. Admins/volunteers are named accounts in the
# `admin_users` table with scrypt-hashed passwords. Create the first one (and
# recover if you're ever locked out) with:  npm run create-admin
# Add more, and manage roles/permissions, in Admin → Settings → Admin Users.

CRON_SECRET=your-cron-secret-7187vj398742312y823019
RECONCILE_WINDOW_DAYS=30